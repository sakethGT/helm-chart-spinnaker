    style Front50 fill:#00b4d8,stroke:#0096b7,color:#fff
    style Echo fill:#00b4d8,stroke:#0096b7,color:#fff
    style Igor fill:#00b4d8,stroke:#0096b7,color:#fff
    style Rosco fill:#00b4d8,stroke:#0096b7,color:#fff
    style Redis fill:#dc3545,stroke:#a71d2a,color:#fff
